# =============================================================================
# Keycloak OIDC Configuration for garage-webui (via OAuth2 Proxy)
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# --- Keycloak Realm ---
# The OIDC issuer URL used for JWT validation (browser-facing).
# Must match the Keycloak realm's public URL (KC_HOSTNAME in keycloak service).
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/garage

# OAuth2 client credentials created in the Keycloak realm garage.
# In Keycloak: Clients -> Create -> Client ID: garage-webui, Client authentication: ON
KEYCLOAK_CLIENT_ID=garage-webui
KEYCLOAK_CLIENT_SECRET=

# --- OAuth2 Proxy ---
# Full redirect URL (must match Keycloak client's Valid Redirect URIs).
OAUTH2_REDIRECT_URL=http://localhost:3909/oauth2/callback

# Cookie secret for encrypting session cookies (32 bytes, base64url-encoded).
# Generate with: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_COOKIE_SECRET=

# Set to "true" if serving behind HTTPS, "false" for plain HTTP.
OAUTH2_COOKIE_SECURE=false

# Restrict to email domains (comma-separated) or "*" for any authenticated user.
OAUTH2_EMAIL_DOMAINS=*

# --- Keycloak Admin (for the local Keycloak container) ---
# Admin console: http://localhost:8080/admin/ (admin / ${KEYCLOAK_ADMIN_PASSWORD})
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloak
